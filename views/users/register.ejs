    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eng . Fathy Abdelaziz</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

</head>
<body>
 <%- include('../partials/flash') %>
 <a style="text-decoration: none;" href="/"><span class="fs-1" style=" cursor: pointer; margin: 10px 0px 0px 20px;">&#8592</span></a>
   <div style="width: 85%; margin: 40px auto; border: 1px solid rgba(24, 24, 195, 0.416); border-radius: 20px; background-color: white; padding: 15px; box-shadow: 0px 10px 15px rgba(6, 4, 123, 0.3);">
    
      <h1 class="my-3" style="font-family: 'Cinzel' , sans-serif; font-weight: 700;">Register</h1>
    <form action="/register" method="post" novalidate class="validated-form">
   <div class="input-group mb-3 has-validation">
  <span class="input-group-text"><i class="bi bi-person"></i></span>
  <div class="form-floating">
    <input type="text" class="form-control"  id="floatingFirstName" name="firstname" required placeholder="First Name">
    <label for="floatingFirstName">First Name</label>
   
 
   <div class="valid-feedback mx-1">
      looks good.
   </div>
   <div class="invalid-feedback mx-1">
      Please enter your first name.
   </div>
     </div>
</div>
            <div class="input-group mb-3 has-validation">
  <span class="input-group-text"><i class="bi bi-person"></i></span>
  <div class="form-floating">
    <input type="text" class="form-control" id="floatingInputGroup1" name="lastname" required placeholder="Last Name">
    <label for="floatingInputGroup1">Last Name</label>
    
  
   <div class="valid-feedback mx-1">
      looks good.
   </div>
<div class="invalid-feedback mx-1">
      Please enter your last name.
   </div>
    </div>
     </div>
 <div class="input-group mb-3 has-validation">
  <span class="input-group-text"><i class="bi bi-telephone"></i></span>
  <div class="form-floating">
    <input type="tel" pattern="^01[0125][0-9]{8}$" maxlength="11" minlength="11" class="form-control" id="floatingInputGroup1" name="username" required placeholder="Student Phone Number">
    <label for="floatingInputGroup1">Student Phone Number</label>

 
   <div class="valid-feedback mx-1">
      looks good.
   </div>
   <div class="invalid-feedback mx-1">
      Please enter a valid phone number.
   </div>
</div>
     </div>
 <div class="input-group mb-3 has-validation">
  <span class="input-group-text"><i class="bi bi-telephone"></i></span>
  <div class="form-floating">
    <input type="tel" maxlength="11" minlength="11"   pattern="^01[0125][0-9]{8}$" class="form-control" id="floatingInputGroup1" name="parentphoneNumber" required placeholder="Parent's Phone Number">
    <label for="floatingInputGroup1">Parent's Phone Number</label>
   
 
   <div class="valid-feedback mx-1">
      looks good.
   </div>
    <div class="invalid-feedback mx-1">
      Please enter a valid phone number.
   </div>
     </div>
</div>
 <div class="input-group mb-3 has-validation">
  <span class="input-group-text"><i class="bi bi-lock"></i></span>
  <div class="form-floating">
    <input type="password" class="form-control" id="floatingInputGroup1" name="password" required placeholder="Password">
    <label for="floatingInputGroup1">Password</label>

 
   <div class="valid-feedback mx-1">
      looks good.
   </div>
    <div class="invalid-feedback mx-1">
      Please provide a password.
   </div>
</div>
     </div>

    <div class="input-group mb-3 has-validation">
        <span class="input-group-text">   <i class="bi bi-mortarboard"></i></span>
        <select name="stage" class="form-select" >
  <option selected disabled>select your stage</option>
  <option value="2">Secondary Two</option>
  <option value="3">Secondary Three</option>
</select>
<div class="valid-feedback mx-1">
   Looks good!
</div>
<div class="invalid-feedback mx-1">
   Please select your stage.
</div>
    </div>
    <div class="d-flex justify-content-between">
           <button style=" justify-content: center; align-items: center;" class="me-auto btn btn-primary w-25 fw-4 font-bold">Register</button>
    <p style="font-family: 'Quicksand' , sans-serif;">Already have an account? <a href="/login">Register</a></p>  

         </div>
    </form>
</div>
</div>
<script>
   // Example starter JavaScript for disabling form submissions if there are invalid fields
(() => {
  'use strict'

  // Fetch all the forms we want to apply custom Bootstrap validation styles to
  const forms = document.querySelectorAll('.validated-form')

  // Loop over them and prevent submission
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault()
        event.stopPropagation()
      }

      form.classList.add('was-validated')
    }, false)
  })
})()
</script>
</body>
</html>

