<% layout('layouts/boilerplate') %>
<div style="margin-top: 20px;">
<a href="/" style="margin-top: 20px; text-decoration: none;">
      <span class="fs-1" style=" cursor: pointer; margin: 90px 0px 0px 20px;">&#8592</span>

</a>
</div>

<h1 class="text-center m-3" style="font-family: 'Cinzel', sans-serif;">Senior Two <span class="text-primary">Applied</span></h1>

<div>
  <div class="card m-3 border-0 justify-content-center">
    <details style="box-shadow: 0px 10px 15px rgba(0,0,0,0.3); background-color: rgb(14, 97, 198); border: none;" class="border-3 rounded overflow-hidden py-1">
      <summary style="font-family: 'Montserrat', sans-serif; padding: 1rem;" class="d-flex cursor-pointer font-bold text-white">
        <div class="d-flex align-items-center">
          <i style="color: white; background-color: blue; border-radius: 50%; padding: 8px;" class="bi bi-book-fill mx-2"></i>Session 1
        </div>
        <i class="bi bi-chevron-down ms-auto"></i>
      </summary>

      <div style="background-color: aliceblue; width: 100%; margin: 0; padding: 0;" class="w-100 m-0">
        <div>
          <p style="padding: 16px 16px 0px 16px; font-family: 'Quicksand', sans-serif; font-size: x-large;">Lesson One</p>
          <a href="/senior3"> 
            <button class="btn btn-outline-primary m-3">Part One &#10139;</button>
          </a>   
        </div>
        <hr>
        <div>
          <button class="btn btn-outline-primary m-3">Part Two &#10139;</button>
        </div>
        <hr>
        <div>
          <button class="btn btn-outline-primary m-3">Part Three &#10139;</button>
        </div>
      </div>
    </details>
  </div>

  <div class="card m-3 border-0 justify-content-center">
    <details style="box-shadow: 0px 10px 15px rgba(0,0,0,0.3); background-color: rgb(14, 97, 198); border: none;" class="border-3 rounded overflow-hidden py-1">
      <summary style="font-family: 'Montserrat', sans-serif; padding: 1rem;" class="d-flex cursor-pointer font-bold text-white">
        <div class="d-flex align-items-center">
          <i style="color: white; background-color: blue; border-radius: 50%; padding: 8px;" class="bi bi-book-fill mx-2"></i>Session 2
        </div>
        <i class="bi bi-chevron-down ms-auto"></i>
      </summary>

      <div style="background-color: aliceblue; width: 100%; margin: 0; padding: 0;" class="w-100 m-0">
        <div>
          <p style="padding: 16px 16px 0px 16px; font-family: 'Quicksand', sans-serif; font-size: x-large;">Lesson One</p>
          
          <% if (lessonExamId) { %>
            <%if(hasCompletedExam){%>
              <button class="btn btn-warning m-3 fw-bold">Exam Completed<i class="bi bi-check2"></i></button>
    <br>        <% } else{%>
                   <a href="/exams/<%= lessonExamId %>">
                <button class="btn btn-warning m-3 fw-bold">
                    Enter the Exam
                </button>
            </a>
            <% } %>
                <% } %>
            <% if (hasCompletedExam) { %>
              <a href="/senior3"> 
                <button class="btn btn-outline-primary m-3">Part One &#10139;</button>
              </a>   <hr>
               <div>
          <button class="btn btn-outline-primary m-3">Part Two &#10139;</button>
        </div>
        <hr>
        <div>
          <button class="btn btn-outline-primary m-3">Part Three &#10139;</button>
        </div>
            <% } else { %>
              <button class="btn btn-outline-secondary m-3" disabled data-bs-toggle="tooltip" title="You must finish the exam first!">
                Part One &#10139; (Locked)
              </button>
               <hr>
               <div>
          <button class="btn btn-outline-primary m-3" disabled>Part Two &#10139; (Locked)</button>
        </div>
        <hr>
        <div>
          <button class="btn btn-outline-primary m-3" disabled>Part Three &#10139; (Locked)</button>
        </div>
            <% } %>
        </div>
        <hr>
       
      </div>
    </details>
  </div>
</div>