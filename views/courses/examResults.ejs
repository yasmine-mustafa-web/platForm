<% layout('layouts/boilerplate') %>

<div class="container my-5">
    <h1 class="text-center my-4" style="font-family: 'Cinzel' , serif; font-weight: 800;">Your Exam Marks</h1>
    
    <table class="table table-striped table-hover mt-3">
        <thead class="table-primary">
            <tr style="font-family: 'Quicksand' , sans-serif;">
                <th>Exam Name</th>
                <th>Date Taken</th>
                <th>Score</th>
                <th>Status</th>
            </tr>   
        </thead>
        <tbody>
            <% for(let result of results) { %>
                <tr>
                    <td><%= result.exam.title %></td>
                    <td><%= result.createdAt.toLocaleDateString() %></td>
                    <td><%= result.score %> / <%= result.totalPointsAvailable %></td>
                    <td>
                        <% if(result.score >= (result.totalPointsAvailable / 2)) { %>
                            <span class="badge bg-success">Passed</span>
                        <% } else { %>
                            <span class="badge bg-danger">Failed</span>
                        <% } %>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>