<% layout('layouts/boilerplate') %>
<div style="margin-top: 20px;">
<a href="/" style="margin-top: 20px; text-decoration: none;">
      <span class="fs-1" style=" cursor: pointer; margin: 90px 0px 0px 20px;">&#8592</span>

</a>
</div>

<h1 class="text-center m-3" style="font-family: 'Cinzel', sans-serif;">Senior Three</h1>
<div class="accordion accordion-flush" id="accordionFlushExample">
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button style="font-family: 'Quicksand' , sans-serif; border-radius: 10px;" class="bg-primary accordion-button collapsed text-white" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="false" aria-controls="flush-collapseOne">
     <i class="bi bi-book-fill me-2"></i> Session Two
      </button>
    </h2>
    <div id="flush-collapseOne" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
      <div class="accordion-body"> <div style="background-color: aliceblue; width: 100%; margin: 0; padding: 0;" class="w-100 m-0">
        <div>
          <p style="padding: 16px 16px 0px 16px; font-family: 'Quicksand', sans-serif; font-size: x-large;">Lesson One</p>
          
          <% if (lessonExamId) { %>
            <%if(hasCompletedExam){%>
              <button class="btn btn-warning m-3 fw-bold">Exam Completed<i class="bi bi-check2"></i></button>
    <br>        <% } else{%>
                   <a href="/exams/<%= lessonExamId %>">
                <button class="btn btn-warning m-3 fw-bold">
                    Enter the Exam
                </button>
            </a>
            <% } %>
                <% } %>
            <% if (hasCompletedExam) { %>
              <a href="/senior3"> 
                <button class="btn btn-outline-primary m-3">Part One &#10139;</button>
              </a>   <hr>
               <div>
          <button class="btn btn-outline-primary m-3">Part Two &#10139;</button>
        </div>
        <hr>
        <div>
          <button class="btn btn-outline-primary m-3">Part Three &#10139;</button>
        </div>
            <% } else { %>
              <button class="btn btn-outline-secondary m-3" disabled data-bs-toggle="tooltip" title="You must finish the exam first!">
                Part One &#10139; (Locked)
              </button>
               <hr>
               <div>
          <button class="btn btn-outline-primary m-3" disabled>Part Two &#10139; (Locked)</button>
        </div>
        <hr>
        <div>
          <button class="btn btn-outline-primary m-3" disabled>Part Three &#10139; (Locked)</button>
        </div>
            <% } %>
        </div>
        <hr>
       
      </div></div>
    </div>
  </div>
  <br>

  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseThree" aria-expanded="false" aria-controls="flush-collapseThree">
        Accordion Item #3
      </button>
    </h2>
    <div id="flush-collapseThree" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
      <div class="accordion-body">Placeholder content for this accordion, which is intended to demonstrate the <code>.accordion-flush</code> class. This is the third item’s accordion body. Nothing more exciting happening here in terms of content, but just filling up the space to make it look, at least at first glance, a bit more representative of how this would look in a real-world application.</div>
    </div>
  </div>
</div>
</div>
<br>